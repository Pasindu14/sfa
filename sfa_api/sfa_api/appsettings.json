{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "SFA.API",
    "Audience": "SFA.Clients",
    "SecretKey": "",
    "AccessTokenExpiryMinutes": 300,
    "RefreshTokenExpiryDays": 7
  },
  "Storage": {
    "Provider": "Azure",
    "AzureBlobConnectionString": "",
    "ContainerName": "sfa-uploads"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ]
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "RateLimit": {
    "GlobalPermitLimit": 100,
    "GlobalWindowSeconds": 60,
    "AuthPermitLimit": 20,
    "AuthWindowSeconds": 60,
    "TestPermitLimit": 1,
    "TestWindowSeconds": 60
  },
  "Cache": {
    "DefaultExpiryMinutes": 30,
    "ShortExpiryMinutes": 15,
    "LongExpiryMinutes": 60
  },
  "AuditLogRetentionDays": 90
}